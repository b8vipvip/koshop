[Unit]
Description=Koshop seller console BFF
After=network.target
[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/koshop/apps/koshop-seller-console/server
EnvironmentFile=/etc/koshop/seller-bff.env
ExecStart=/usr/bin/node server.mjs
Restart=always
RestartSec=3
NoNewPrivileges=true
[Install]
WantedBy=multi-user.target
