HOST=127.0.0.1
PORT=18100
DUJIAO_API_BASE=http://127.0.0.1:8080
DUJIAO_ADMIN_TOKEN=
LHC_API_BASE=http://127.0.0.1
LHC_API_TOKEN=
# Override these only when the installed Dujiao/LHC API paths differ.
DUJIAO_DASHBOARD_PATH=/api/v1/admin/dashboard/overview
DUJIAO_PRODUCTS_PATH=/api/v1/admin/products
DUJIAO_ORDERS_PATH=/api/v1/admin/orders
DUJIAO_FINANCE_PATH=/api/v1/admin/payments
LHC_CHATS_PATH=/index.php/restapi/onlinechats
# Must match KOSHOP_CHAT_API_TOKEN in the LHC PHP runtime; never expose it to Vite/browser env.
# LHC_API_TOKEN=replace-with-a-long-random-token
SELLER_DISPLAY_NAME=admin
SELLER_AVATAR_URL=
